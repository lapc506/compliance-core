{
  "name": "compliance-core",
  "private": true,
  "version": "0.1.0-dev",
  "description": "Sidecar library for KYC, sanctions screening, and audit log as hexagonal -core for the lapc506 ecosystem.",
  "license": "BUSL-1.1",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22.11.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "proto:gen": "buf generate",
    "proto:lint": "buf lint",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@bufbuild/buf": "1.47.2",
    "@types/node": "22.9.0",
    "@vitest/coverage-v8": "2.1.4",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
