# compliance-core — environment variable template.
# Copy to `.env` for local dev. NEVER commit a populated `.env`.
# Secrets (provider API keys, HMAC webhook secrets) are loaded via ProviderCredentialVault / SecretsStorePort — NOT env vars.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# gRPC + REST ports (spec §3.3 — distinct from agentic-core :50051/:8765 and
# invoice-core :50061/:8766 to allow multi-sidecar on the same pod).
# -----------------------------------------------------------------------------
GRPC_PORT=50071
REST_PORT=8767
METRICS_PORT=9464

# -----------------------------------------------------------------------------
# Single-tenant v1 (multi-tenant deferred to Fase 3)
# -----------------------------------------------------------------------------
TENANT_ID=habitanexus-cr

# -----------------------------------------------------------------------------
# PostgreSQL
# Local dev default targets docker-compose postgres:16 service.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://compliance:compliance@localhost:5432/compliance_core

# -----------------------------------------------------------------------------
# Redis (idempotency + rate-limit buckets)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# HashiCorp Vault (ProviderCredentialVault backend)
# VAULT_MODE: vault | sealed-secrets | memory (memory for tests only)
# -----------------------------------------------------------------------------
VAULT_MODE=vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token

# Sealed-secrets mount (K8s sidecar mode alternative to Vault)
SEALED_SECRETS_MOUNT=/run/secrets/compliance

# -----------------------------------------------------------------------------
# Persona webhook secret path in Vault (never the secret itself in env)
# -----------------------------------------------------------------------------
PERSONA_WEBHOOK_SECRET_PATH=compliance/habitanexus-cr/providers/persona/webhook-secret
ONDATO_WEBHOOK_SECRET_PATH=compliance/habitanexus-cr/providers/ondato/webhook-secret

# -----------------------------------------------------------------------------
# OpenTelemetry
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=compliance-core
OTEL_RESOURCE_ATTRIBUTES=service.namespace=compliance,service.version=0.1.0-dev

# -----------------------------------------------------------------------------
# Sanctions screening
# -----------------------------------------------------------------------------
SANCTIONS_MATCH_THRESHOLD=80
OFAC_SDN_URL=https://sanctionslist.ofac.treas.gov/Home/ConsolidatedList
OFAC_CACHE_DIR=/tmp/compliance/ofac

# -----------------------------------------------------------------------------
# Audit log
# -----------------------------------------------------------------------------
AUDIT_EXPORT_SIGNING_KEY_PATH=compliance/habitanexus-cr/audit/export-signing-key
